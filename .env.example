# Copy to .env and fill in. NEVER commit a real .env.

# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
BODY_SIZE_LIMIT=4mb

# --- Datastores (required once their chunks land) ---
MONGO_URI=mongodb://localhost:27017/securellm
REDIS_URL=redis://localhost:6379

# --- Crypto (generate strong random values; required once their chunks land) ---
# 32+ char random string used to pseudonymize key IDs in logs.
LOG_PSEUDONYM_SECRET=
# 32-byte key, base64-encoded, for AES-256-GCM PII vault encryption.
PII_ENCRYPTION_KEY=

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# --- LLM provider (optional: if absent, service starts degraded and /v1/chat returns 503) ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# --- Audit retention ---
AUDIT_LOG_TTL_DAYS=90
PII_VAULT_TTL_DAYS=30
